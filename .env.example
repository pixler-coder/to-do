# ── NeoTask Environment Configuration ──────────────────────────────
# Copy this file to .env and adjust values for your environment.
# Do NOT commit .env to version control.

# Database connection URL
# For SQLite (default):  sqlite:///./todo.db
# For PostgreSQL:        postgresql://user:pass@host:5432/dbname
DATABASE_URL=sqlite:///./todo.db

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# Debug mode — set to false in production
# When true: enables /docs (Swagger UI) and /redoc endpoints
# When false: disables interactive API docs
DEBUG=true

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
